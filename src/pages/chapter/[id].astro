---
import "../../styles/global.css";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/common/Navbar";
import { apiService } from "../../utils/api";
import Chapter from "../_Chapter";
export const prerender = false;

const { id = "" } = Astro.params;

let manhwaTitle = "";
try {
  const chapterDetail = await apiService.getChapterDetail(id);
  const mangaId = chapterDetail?.data?.manga_id;
  if (mangaId) {
    const manhwaDetail = await apiService.getDetail(mangaId);
    manhwaTitle = manhwaDetail?.data?.title || "";
  }
} catch (error) {
  console.error("Failed to fetch chapter details:", error);
}
---

<Layout title={manhwaTitle ? `${manhwaTitle} - Kurokami` : "Chapter - Kurokami"}>
  <Navbar slot="body" client:only="react" />
  <Chapter slot="body" idChapter={id} client:only="react" />
</Layout>
